# ---------------------------------------------------------------------------
# Prime Air Dashboard — environment variables
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# Only NEXT_PUBLIC_* values reach the browser; everything else is server-only.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + Auth) -------------------------------------------
# Project URL + anon key are safe for the browser (RLS enforced).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is SERVER ONLY. Used by API routes that the voice agent
# calls (awb-lookup, pickup) and by the call-sync job. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Vapi (voice agent) ---------------------------------------------------
# Your Vapi PRIVATE API key. The dashboard uses it server-side against the
# Vapi REST API (api.vapi.ai) to read/update the assistant and pull calls.
# The provisioning script (scripts/provision-vapi.ts) uses the same key with
# the Vapi MCP server. Set this in Vercel so the Assistant page populates.
VAPI_API_KEY=your-vapi-private-api-key
VAPI_MCP_URL=https://mcp.vapi.ai/sse
# Optional REST base override (defaults to https://api.vapi.ai).
# VAPI_BASE_URL=https://api.vapi.ai

# The assistant this dashboard reads/edits and syncs calls from.
# Left blank until you run `npm run vapi:provision`, which prints the id.
VAPI_ASSISTANT_ID=

# Shared secret Vapi signs server-message webhooks with. Set the same value
# in the Vapi assistant's Server URL secret. Used by /api/vapi/webhook.
VAPI_WEBHOOK_SECRET=generate-a-long-random-string

# Public base URL of THIS app, used when provisioning the awb-lookup tool
# URL on the Vapi assistant (e.g. https://prime-air.vercel.app).
APP_BASE_URL=http://localhost:3000
